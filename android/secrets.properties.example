# Copy this file to `secrets.properties` (gitignored) and fill in real values.
# These are read by app/build.gradle.kts and exposed to Kotlin code via BuildConfig.
#
# How to obtain GOOGLE_WEB_CLIENT_ID:
#   1. Go to https://console.cloud.google.com → Credentials.
#   2. Create OAuth 2.0 Client ID, type "Web application" (NOT Android).
#      You need a "Web" client even for Android because the Credential Manager
#      issues server-auth ID tokens that the backend will validate.
#   3. Add `https://apestogether.ai` to "Authorized JavaScript origins" if the
#      web flow ever runs there (optional for mobile-only).
#   4. Copy the Client ID (looks like 1234567-abcdef.apps.googleusercontent.com)
#      and paste below.
#   5. ALSO create an Android OAuth 2.0 Client ID with package name
#      `com.apestogether.app` and the SHA-1 of your debug + release signing keys.
#      Get debug SHA-1 with:
#        keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android
#      Get release SHA-1 from Google Play Console → App signing → App signing
#      key certificate.
#   The Android Client ID does NOT go in secrets — it's identified implicitly
#   by package + SHA-1 once the Google project knows about both clients.

GOOGLE_WEB_CLIENT_ID=

# Optional: override API base for development against a staging deployment.
# Leave blank to use the default in app/build.gradle.kts (production URL).
# API_BASE_URL=https://staging.apestogether.ai/api/mobile/
