<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- This XML theme exists only to set the splash background color for
         the brief moment between launcher tap and Compose taking over.
         All real styling lives in ApesTogetherTheme (Compose). -->
    <style name="Theme.ApesTogether" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
