{
  "version": 2,
  "name": "stock-portfolio-app",
  "builds": [
    {
      "src": "api/vercel.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "includeFiles": "public/.well-known/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/api/vercel.py"
    }
  ],
  "crons": [
    {
      "path": "/api/health",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/cron/collect-intraday-data",
      "schedule": "*/15 * * * 1-5"
    },
    {
      "path": "/api/cron/market-open",
      "schedule": "31 13 * * 1-5"
    },
    {
      "path": "/api/cron/market-close", 
      "schedule": "5 20 * * 1-5"
    },
    {
      "path": "/api/cron/cleanup-intraday-data",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/auto-create-bots",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/monthly-payouts",
      "schedule": "0 9 3 * *"
    },
    {
      "path": "/api/cron/drift-check",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron/snapshot-audit",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/cron/refresh-daily-bars?part=1&of=2",
      "schedule": "30 22 * * 1-5"
    },
    {
      "path": "/api/cron/refresh-daily-bars?part=2&of=2",
      "schedule": "32 22 * * 1-5"
    },
    {
      "path": "/api/cron/refresh-fundamentals?part=1&of=3",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/cron/refresh-fundamentals?part=2&of=3",
      "schedule": "2 23 * * 0"
    },
    {
      "path": "/api/cron/refresh-fundamentals?part=3&of=3",
      "schedule": "4 23 * * 0"
    }
  ]
}
